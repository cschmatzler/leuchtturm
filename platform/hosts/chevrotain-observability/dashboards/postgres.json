			"targets": [
				{
					"expr": "sum(rate(pg_stat_database_xact_rollback{job=\"postgres\", datname=\"chevrotain\"}[$__rate_interval]))",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 71,
			"type": "stat",
			"title": "Max Connections",
			"gridPos": { "h": 4, "w": 2, "x": 22, "y": 1 },
