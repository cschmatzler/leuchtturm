		{
			"id": 2,
			"type": "stat",
			"title": "Uptime",
			"gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "dtdurations",
					"color": { "mode": "fixed", "fixedColor": "text" },
					"thresholds": {
						"mode": "absolute",
						"steps": [{ "color": "text", "value": null }]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "none",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "time() - process_start_time_seconds{job=\"postgres\"}",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 4,
			"type": "stat",
			"title": "Database Size",
