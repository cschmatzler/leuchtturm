			"targets": [
				{
					"expr": "pg_settings_max_connections{job=\"postgres\"}",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 8,
			"type": "gauge",
			"title": "Cache Hit Ratio",
			"gridPos": { "h": 5, "w": 6, "x": 0, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "red", "value": null },
							{ "color": "orange", "value": 90 },
							{ "color": "green", "value": 99 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "sum(rate(pg_stat_database_blks_hit{job=\"postgres\", datname=\"chevrotain\"}[$__rate_interval])) / (sum(rate(pg_stat_database_blks_hit{job=\"postgres\", datname=\"chevrotain\"}[$__rate_interval])) + sum(rate(pg_stat_database_blks_read{job=\"postgres\", datname=\"chevrotain\"}[$__rate_interval]))) * 100",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 9,
			"type": "gauge",
			"title": "Connection Usage",
			"gridPos": { "h": 5, "w": 6, "x": 6, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 70 },
							{ "color": "red", "value": 90 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "sum(pg_stat_database_numbackends{job=\"postgres\"}) / scalar(pg_settings_max_connections{job=\"postgres\"}) * 100",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 10,
			"type": "gauge",
			"title": "Rollback Ratio",
			"gridPos": { "h": 5, "w": 6, "x": 12, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"decimals": 2,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 1 },
							{ "color": "red", "value": 5 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "sum(rate(pg_stat_database_xact_rollback{job=\"postgres\", datname=\"chevrotain\"}[$__rate_interval])) / (sum(rate(pg_stat_database_xact_commit{job=\"postgres\", datname=\"chevrotain\"}[$__rate_interval])) + sum(rate(pg_stat_database_xact_rollback{job=\"postgres\", datname=\"chevrotain\"}[$__rate_interval]))) * 100",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
