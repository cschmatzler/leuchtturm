{
	"id": null,
	"uid": "node",
	"title": "Node",
	"description": "Host metrics from node_exporter — CPU, memory, disk, network, system",
	"tags": ["node-exporter"],
	"editable": true,
	"graphTooltip": 2,
	"schemaVersion": 39,
	"time": { "from": "now-1h", "to": "now" },
	"refresh": "30s",
	"timezone": "browser",
	"fiscalYearStartMonth": 0,
	"templating": {
		"list": [
			{
				"name": "instance",
				"type": "query",
				"label": "Host",
				"datasource": { "type": "prometheus", "uid": "prometheus" },
				"definition": "label_values(node_uname_info{job=\"node\", instance=~\"$instance\"}, instance)",
				"query": "label_values(node_uname_info{job=\"node\", instance=~\"$instance\"}, instance)",
				"refresh": 1,
				"includeAll": true,
				"multi": true,
				"allValue": ".*",
				"current": {
					"selected": true,
					"text": "All",
					"value": "$__all"
				},
				"sort": 1
			}
		]
	},
	"annotations": { "list": [] },
	"links": [],
	"panels": [
		{
			"id": 1,
			"type": "row",
			"title": "Overview",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 2,
			"type": "table",
			"title": "Host Overview",
			"gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "instance" },
						"properties": [
							{ "id": "displayName", "value": "Host" },
							{ "id": "custom.width", "value": 120 }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Value #A" },
						"properties": [
							{ "id": "displayName", "value": "Uptime" },
							{ "id": "unit", "value": "dtdurations" }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Value #B" },
						"properties": [
							{ "id": "displayName", "value": "CPU" },
							{ "id": "unit", "value": "percent" },
							{ "id": "decimals", "value": 1 },
							{
								"id": "thresholds",
								"value": {
									"mode": "absolute",
									"steps": [
										{ "color": "green", "value": null },
										{ "color": "orange", "value": 70 },
										{ "color": "red", "value": 90 }
									]
								}
							},
							{ "id": "custom.cellOptions", "value": { "type": "color-text" } }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Value #C" },
						"properties": [
							{ "id": "displayName", "value": "Load/Core" },
							{ "id": "unit", "value": "short" },
							{ "id": "decimals", "value": 2 },
							{
								"id": "thresholds",
								"value": {
									"mode": "absolute",
									"steps": [
										{ "color": "green", "value": null },
										{ "color": "orange", "value": 0.7 },
										{ "color": "red", "value": 1.0 }
									]
								}
							},
							{ "id": "custom.cellOptions", "value": { "type": "color-text" } }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Value #D" },
						"properties": [
							{ "id": "displayName", "value": "RAM" },
							{ "id": "unit", "value": "percent" },
							{ "id": "decimals", "value": 1 },
							{
								"id": "thresholds",
								"value": {
									"mode": "absolute",
									"steps": [
										{ "color": "green", "value": null },
										{ "color": "orange", "value": 70 },
										{ "color": "red", "value": 90 }
									]
								}
							},
							{ "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic" } },
							{ "id": "min", "value": 0 },
							{ "id": "max", "value": 100 }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Value #E" },
						"properties": [
							{ "id": "displayName", "value": "Swap" },
							{ "id": "unit", "value": "percent" },
							{ "id": "decimals", "value": 1 },
							{
								"id": "thresholds",
								"value": {
									"mode": "absolute",
									"steps": [
										{ "color": "green", "value": null },
										{ "color": "orange", "value": 25 },
										{ "color": "red", "value": 50 }
									]
								}
							},
							{ "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic" } },
							{ "id": "min", "value": 0 },
							{ "id": "max", "value": 100 }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Value #F" },
						"properties": [
							{ "id": "displayName", "value": "Disk" },
							{ "id": "unit", "value": "percent" },
							{ "id": "decimals", "value": 1 },
							{
								"id": "thresholds",
								"value": {
									"mode": "absolute",
									"steps": [
										{ "color": "green", "value": null },
										{ "color": "orange", "value": 70 },
										{ "color": "red", "value": 90 }
									]
								}
							},
							{ "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic" } },
							{ "id": "min", "value": 0 },
							{ "id": "max", "value": 100 }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Time" },
						"properties": [{ "id": "custom.hidden", "value": true }]
					}
				]
			},
			"options": {
				"showHeader": true,
				"sortBy": [{ "displayName": "Host", "desc": false }]
			},
			"transformations": [{ "id": "merge", "options": {} }],
			"targets": [
				{
					"expr": "time() - node_boot_time_seconds{job=\"node\", instance=~\"$instance\"}",
					"format": "table",
					"instant": true,
					"refId": "A"
				},
				{
					"expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"}[5m])))",
					"format": "table",
					"instant": true,
					"refId": "B"
				},
				{
					"expr": "node_load5{job=\"node\", instance=~\"$instance\"} / count by (instance) (node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"})",
					"format": "table",
					"instant": true,
					"refId": "C"
				},
				{
					"expr": "(1 - node_memory_MemAvailable_bytes{job=\"node\", instance=~\"$instance\"} / node_memory_MemTotal_bytes{job=\"node\", instance=~\"$instance\"}) * 100",
					"format": "table",
					"instant": true,
					"refId": "D"
				},
				{
					"expr": "((node_memory_SwapTotal_bytes{job=\"node\", instance=~\"$instance\"} - node_memory_SwapFree_bytes{job=\"node\", instance=~\"$instance\"}) / node_memory_SwapTotal_bytes{job=\"node\", instance=~\"$instance\"}) * 100",
					"format": "table",
					"instant": true,
					"refId": "E"
				},
				{
					"expr": "(1 - node_filesystem_avail_bytes{job=\"node\", instance=~\"$instance\", mountpoint=\"/\", fstype!=\"rootfs\"} / node_filesystem_size_bytes{job=\"node\", instance=~\"$instance\", mountpoint=\"/\", fstype!=\"rootfs\"}) * 100",
					"format": "table",
					"instant": true,
					"refId": "F"
				}
			]
		},
		{
			"id": 12,
			"type": "row",
			"title": "CPU",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 13,
			"type": "timeseries",
			"title": "CPU Busy by Host",
			"description": "Overall CPU busy percentage per host",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "percent",
					"min": 0,
					"max": 100,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineWidth": 2,
						"lineInterpolation": "smooth",
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"calcs": ["mean", "lastNotNull"]
				}
			},
			"targets": [
				{
					"expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"}[$__rate_interval])))",
					"legendFormat": "{{instance}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 14,
			"type": "timeseries",
			"title": "System Load",
			"description": "System load averages with CPU core count reference",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "short",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 0,
						"lineInterpolation": "smooth",
						"lineWidth": 2,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "CPU Cores" },
						"properties": [
							{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
							{ "id": "custom.lineWidth", "value": 1 },
							{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
						]
					}
				]
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"calcs": ["mean", "lastNotNull"]
				}
			},
			"targets": [
				{
					"expr": "node_load1{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "{{instance}} load 1m",
					"refId": "A"
				},
				{
					"expr": "node_load5{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "{{instance}} load 5m",
					"refId": "B"
				},
				{
					"expr": "node_load15{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "{{instance}} load 15m",
					"refId": "C"
				},
				{
					"expr": "count by (instance) (node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"})",
					"legendFormat": "{{instance}} cores",
					"refId": "D"
				}
			]
		},
		{
			"id": 15,
			"type": "row",
			"title": "Memory",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 16,
			"type": "timeseries",
			"title": "Memory — $instance",
			"description": "Memory breakdown — used, buffers, cached, free",
			"repeat": "instance",
			"repeatDirection": "h",
			"maxPerRow": 2,
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "fixed" },
					"unit": "bytes",
					"min": 0,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 80,
						"lineWidth": 0,
						"lineInterpolation": "smooth",
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "normal" }
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "Used" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#56A64B" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Buffers" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Cached" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3274D9" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Free" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#C8C8C8" } }]
					}
				]
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": {
					"displayMode": "list",
					"placement": "bottom",
					"calcs": []
				}
			},
			"targets": [
				{
					"expr": "node_memory_MemTotal_bytes{job=\"node\", instance=\"$instance\"} - node_memory_MemFree_bytes{job=\"node\", instance=\"$instance\"} - node_memory_Buffers_bytes{job=\"node\", instance=\"$instance\"} - node_memory_Cached_bytes{job=\"node\", instance=\"$instance\"} - node_memory_SReclaimable_bytes{job=\"node\", instance=\"$instance\"}",
					"legendFormat": "Used",
					"refId": "A"
				},
				{
					"expr": "node_memory_Buffers_bytes{job=\"node\", instance=\"$instance\"}",
					"legendFormat": "Buffers",
					"refId": "B"
				},
				{
					"expr": "node_memory_Cached_bytes{job=\"node\", instance=\"$instance\"} + node_memory_SReclaimable_bytes{job=\"node\", instance=\"$instance\"}",
					"legendFormat": "Cached",
					"refId": "C"
				},
				{
					"expr": "node_memory_MemFree_bytes{job=\"node\", instance=\"$instance\"}",
					"legendFormat": "Free",
					"refId": "D"
				}
			]
		},
		{
			"id": 17,
			"type": "timeseries",
			"title": "Swap",
			"description": "Swap usage and I/O activity",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "bytes",
					"min": 0,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 1,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "Swap In" },
						"properties": [
							{ "id": "unit", "value": "Bps" },
							{ "id": "custom.axisPlacement", "value": "right" }
						]
					},
					{
						"matcher": { "id": "byName", "options": "Swap Out" },
						"properties": [
							{ "id": "unit", "value": "Bps" },
							{ "id": "custom.axisPlacement", "value": "right" }
						]
					}
				]
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"calcs": ["mean", "lastNotNull"]
				}
			},
			"targets": [
				{
					"expr": "node_memory_SwapTotal_bytes{job=\"node\", instance=~\"$instance\"} - node_memory_SwapFree_bytes{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "{{instance}} Swap Used",
					"refId": "A"
				},
				{
					"expr": "node_memory_SwapFree_bytes{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "{{instance}} Swap Free",
					"refId": "B"
				},
				{
					"expr": "rate(node_vmstat_pswpin{job=\"node\", instance=~\"$instance\"}[$__rate_interval]) * 4096",
					"legendFormat": "{{instance}} Swap In",
					"refId": "C"
				},
				{
					"expr": "rate(node_vmstat_pswpout{job=\"node\", instance=~\"$instance\"}[$__rate_interval]) * 4096",
					"legendFormat": "{{instance}} Swap Out",
					"refId": "D"
				}
			]
		},
		{
			"id": 18,
			"type": "row",
			"title": "Disk",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 19,
			"type": "timeseries",
			"title": "Disk I/O Throughput",
			"description": "Read/write throughput per device — writes shown negative",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "Bps",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 1,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" },
						"axisCenteredZero": true
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
			},
			"targets": [
				{
					"expr": "rate(node_disk_read_bytes_total{job=\"node\", instance=~\"$instance\", device!~\"dm-.*|loop.*\"}[$__rate_interval])",
					"legendFormat": "{{instance}} {{device}} read",
					"refId": "A"
				},
				{
					"expr": "-rate(node_disk_written_bytes_total{job=\"node\", instance=~\"$instance\", device!~\"dm-.*|loop.*\"}[$__rate_interval])",
					"legendFormat": "{{instance}} {{device}} write",
					"refId": "B"
				}
			]
		},
		{
			"id": 20,
			"type": "timeseries",
			"title": "Disk IOps",
			"description": "Read/write IOPS per device — writes shown negative",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "iops",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 1,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" },
						"axisCenteredZero": true
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
			},
			"targets": [
				{
					"expr": "rate(node_disk_reads_completed_total{job=\"node\", instance=~\"$instance\", device!~\"dm-.*|loop.*\"}[$__rate_interval])",
					"legendFormat": "{{instance}} {{device}} reads",
					"refId": "A"
				},
				{
					"expr": "-rate(node_disk_writes_completed_total{job=\"node\", instance=~\"$instance\", device!~\"dm-.*|loop.*\"}[$__rate_interval])",
					"legendFormat": "{{instance}} {{device}} writes",
					"refId": "B"
				}
			]
		},
		{
			"id": 21,
			"type": "timeseries",
			"title": "Disk I/O Utilization",
			"description": "Percentage of time the disk was busy processing I/O",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "percentunit",
					"min": 0,
					"max": 1,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 1,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
			},
			"targets": [
				{
					"expr": "rate(node_disk_io_time_seconds_total{job=\"node\", instance=~\"$instance\", device!~\"dm-.*|loop.*\"}[$__rate_interval])",
					"legendFormat": "{{instance}} {{device}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 22,
			"type": "bargauge",
			"title": "Filesystem Space Used",
			"description": "Disk space utilization by mount point",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percentunit",
					"min": 0,
					"max": 1,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 0.7 },
							{ "color": "red", "value": 0.9 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"orientation": "horizontal",
