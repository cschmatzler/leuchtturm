{
	"id": null,
	"uid": "node",
	"title": "Node",
	"description": "Host metrics from node_exporter — CPU, memory, disk, network, system",
	"tags": ["node-exporter"],
	"editable": true,
	"graphTooltip": 2,
	"schemaVersion": 39,
	"time": { "from": "now-1h", "to": "now" },
	"refresh": "30s",
	"timezone": "browser",
	"fiscalYearStartMonth": 0,
	"templating": {
		"list": [
			{
				"name": "instance",
				"type": "query",
				"label": "Host",
				"datasource": { "type": "prometheus", "uid": "prometheus" },
				"definition": "label_values(node_uname_info{job=\"node\", instance=~\"$instance\"}, instance)",
				"query": "label_values(node_uname_info{job=\"node\", instance=~\"$instance\"}, instance)",
				"refresh": 1,
				"includeAll": true,
				"multi": false,
				"allValue": ".*",
				"current": {
					"selected": true,
					"text": "All",
					"value": "$__all"
				},
				"sort": 1
			}
		]
	},
	"annotations": { "list": [] },
	"links": [],
	"panels": [
		{
			"id": 1,
			"type": "row",
			"title": "Overview",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 2,
			"type": "stat",
			"title": "Uptime",
			"gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "dtdurations",
					"color": { "mode": "fixed", "fixedColor": "text" },
					"thresholds": {
						"mode": "absolute",
						"steps": [{ "color": "text", "value": null }]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "none",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "time() - node_boot_time_seconds{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 3,
			"type": "stat",
			"title": "CPU Cores",
			"gridPos": { "h": 4, "w": 5, "x": 5, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"color": { "mode": "fixed", "fixedColor": "text" },
					"thresholds": {
						"mode": "absolute",
						"steps": [{ "color": "text", "value": null }]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "none",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "count(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"})",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 4,
			"type": "stat",
			"title": "RAM Total",
			"gridPos": { "h": 4, "w": 5, "x": 10, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "bytes",
					"color": { "mode": "fixed", "fixedColor": "text" },
					"thresholds": {
						"mode": "absolute",
						"steps": [{ "color": "text", "value": null }]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "none",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "node_memory_MemTotal_bytes{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 5,
			"type": "stat",
			"title": "Swap Total",
			"gridPos": { "h": 4, "w": 5, "x": 15, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "bytes",
					"color": { "mode": "fixed", "fixedColor": "text" },
					"thresholds": {
						"mode": "absolute",
						"steps": [{ "color": "text", "value": null }]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "none",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "node_memory_SwapTotal_bytes{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 6,
			"type": "stat",
			"title": "Root FS Total",
			"gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "bytes",
					"color": { "mode": "fixed", "fixedColor": "text" },
					"thresholds": {
						"mode": "absolute",
						"steps": [{ "color": "text", "value": null }]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "none",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "node_filesystem_size_bytes{job=\"node\", instance=~\"$instance\", mountpoint=\"/\", fstype!=\"rootfs\"}",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 7,
			"type": "gauge",
			"title": "CPU Busy",
			"gridPos": { "h": 5, "w": 5, "x": 0, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 70 },
							{ "color": "red", "value": 90 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "(1 - avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"}[$__rate_interval]))) * 100",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 8,
			"type": "gauge",
			"title": "Load / Core",
			"gridPos": { "h": 5, "w": 5, "x": 5, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"decimals": 2,
					"min": 0,
					"max": 2,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 0.7 },
							{ "color": "red", "value": 1.0 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "node_load5{job=\"node\", instance=~\"$instance\"} / count(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"})",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 9,
			"type": "gauge",
			"title": "RAM Used",
			"gridPos": { "h": 5, "w": 5, "x": 10, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 70 },
							{ "color": "red", "value": 90 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "(1 - node_memory_MemAvailable_bytes{job=\"node\", instance=~\"$instance\"} / node_memory_MemTotal_bytes{job=\"node\", instance=~\"$instance\"}) * 100",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 10,
			"type": "gauge",
			"title": "Swap Used",
			"gridPos": { "h": 5, "w": 5, "x": 15, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 25 },
							{ "color": "red", "value": 50 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "((node_memory_SwapTotal_bytes{job=\"node\", instance=~\"$instance\"} - node_memory_SwapFree_bytes{job=\"node\", instance=~\"$instance\"}) / node_memory_SwapTotal_bytes{job=\"node\", instance=~\"$instance\"}) * 100",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 11,
			"type": "gauge",
			"title": "Root FS Used",
			"gridPos": { "h": 5, "w": 4, "x": 20, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 70 },
							{ "color": "red", "value": 90 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "(1 - node_filesystem_avail_bytes{job=\"node\", instance=~\"$instance\", mountpoint=\"/\", fstype!=\"rootfs\"} / node_filesystem_size_bytes{job=\"node\", instance=~\"$instance\", mountpoint=\"/\", fstype!=\"rootfs\"}) * 100",
					"legendFormat": "",
					"refId": "A"
				}
			]
		},
		{
			"id": 12,
			"type": "row",
			"title": "CPU",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 13,
			"type": "timeseries",
			"title": "CPU Usage",
			"description": "CPU time spent in each mode, stacked to 100%",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "fixed" },
					"unit": "percent",
					"min": 0,
					"max": 100,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 80,
						"lineWidth": 0,
						"lineInterpolation": "smooth",
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "normal" }
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "User" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3274D9" } }]
					},
					{
						"matcher": { "id": "byName", "options": "System" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#E02F44" } }]
					},
					{
						"matcher": { "id": "byName", "options": "I/O Wait" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Steal" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8F3BB8" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Nice" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#56A64B" } }]
					},
					{
						"matcher": { "id": "byName", "options": "IRQ" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#33B5E5" } }]
					},
					{
						"matcher": { "id": "byName", "options": "SoftIRQ" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Idle" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#C8C8C8" } }]
					}
				]
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"calcs": ["mean", "lastNotNull"]
				}
			},
			"targets": [
				{
					"expr": "avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"user\"}[$__rate_interval])) * 100",
					"legendFormat": "User",
					"refId": "A"
				},
				{
					"expr": "avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"system\"}[$__rate_interval])) * 100",
					"legendFormat": "System",
					"refId": "B"
				},
				{
					"expr": "avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"iowait\"}[$__rate_interval])) * 100",
					"legendFormat": "I/O Wait",
					"refId": "C"
				},
				{
					"expr": "avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"steal\"}[$__rate_interval])) * 100",
					"legendFormat": "Steal",
					"refId": "D"
				},
				{
					"expr": "avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"nice\"}[$__rate_interval])) * 100",
					"legendFormat": "Nice",
					"refId": "E"
				},
				{
					"expr": "avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"irq\"}[$__rate_interval])) * 100",
					"legendFormat": "IRQ",
					"refId": "F"
				},
				{
					"expr": "avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"softirq\"}[$__rate_interval])) * 100",
					"legendFormat": "SoftIRQ",
					"refId": "G"
				},
				{
					"expr": "avg(rate(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"}[$__rate_interval])) * 100",
					"legendFormat": "Idle",
					"refId": "H"
				}
			]
		},
		{
			"id": 14,
			"type": "timeseries",
			"title": "System Load",
			"description": "System load averages with CPU core count reference",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "short",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 0,
						"lineInterpolation": "smooth",
						"lineWidth": 2,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "CPU Cores" },
						"properties": [
							{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
							{ "id": "custom.lineWidth", "value": 1 },
							{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
						]
					}
				]
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"calcs": ["mean", "lastNotNull"]
				}
			},
			"targets": [
				{
					"expr": "node_load1{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "Load 1m",
					"refId": "A"
				},
				{
					"expr": "node_load5{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "Load 5m",
					"refId": "B"
				},
				{
					"expr": "node_load15{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "Load 15m",
					"refId": "C"
				},
				{
					"expr": "count(node_cpu_seconds_total{job=\"node\", instance=~\"$instance\", mode=\"idle\"})",
					"legendFormat": "CPU Cores",
					"refId": "D"
				}
			]
		},
		{
			"id": 15,
			"type": "row",
			"title": "Memory",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 16,
			"type": "timeseries",
			"title": "Memory Usage",
			"description": "Memory breakdown — used, buffers, cached, free",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "fixed" },
					"unit": "bytes",
					"min": 0,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 80,
						"lineWidth": 0,
						"lineInterpolation": "smooth",
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "normal" }
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "Used" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#56A64B" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Buffers" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Cached" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3274D9" } }]
					},
					{
						"matcher": { "id": "byName", "options": "Free" },
						"properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#C8C8C8" } }]
					}
				]
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": {
					"displayMode": "table",
					"placement": "bottom",
					"calcs": ["mean", "lastNotNull"]
				}
			},
			"targets": [
				{
					"expr": "node_memory_MemTotal_bytes{job=\"node\", instance=~\"$instance\"} - node_memory_MemFree_bytes{job=\"node\", instance=~\"$instance\"} - node_memory_Buffers_bytes{job=\"node\", instance=~\"$instance\"} - node_memory_Cached_bytes{job=\"node\", instance=~\"$instance\"} - node_memory_SReclaimable_bytes{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "Used",
					"refId": "A"
				},
				{
					"expr": "node_memory_Buffers_bytes{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "Buffers",
					"refId": "B"
				},
				{
					"expr": "node_memory_Cached_bytes{job=\"node\", instance=~\"$instance\"} + node_memory_SReclaimable_bytes{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "Cached",
					"refId": "C"
				},
				{
					"expr": "node_memory_MemFree_bytes{job=\"node\", instance=~\"$instance\"}",
					"legendFormat": "Free",
					"refId": "D"
				}
			]
		},
		{
			"id": 17,
			"type": "timeseries",
			"title": "Swap",
			"description": "Swap usage and I/O activity",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "bytes",
					"min": 0,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 1,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": [
					{
						"matcher": { "id": "byName", "options": "Swap In" },
