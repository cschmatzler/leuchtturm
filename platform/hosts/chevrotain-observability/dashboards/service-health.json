			"targets": [
				{
					"expr": "(2 * scalar(max(up{job=\"chevrotain/api\"}))) - (scalar(max(up{job=\"chevrotain/api\"})) * scalar(max((((max(nodejs_eventloop_lag_p99_seconds{job=\"chevrotain/api\"}) > bool 0.25) or on() vector(0)) or ((max(nodejs_heap_size_used_bytes{job=\"chevrotain/api\"}) > bool 536870912) or on() vector(0)) or ((max(chevrotain_api_db_pool_clients{state=\"waiting\"}) > bool 0) or on() vector(0))))))",
