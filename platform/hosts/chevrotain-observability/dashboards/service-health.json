			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"decimals": 0,
					"mappings": [
						{
							"type": "value",
							"options": {
								"0": {
									"text": "Down",
									"index": 0
								},
								"1": {
									"text": "Degraded",
