{
	"id": null,
	"uid": "zero-cache",
	"title": "Zero Cache",
	"description": "Zero traffic and host health via API and node metrics",
	"tags": ["zero", "cache"],
	"editable": true,
	"graphTooltip": 2,
	"schemaVersion": 39,
	"time": { "from": "now-1h", "to": "now" },
	"refresh": "30s",
	"timezone": "browser",
	"fiscalYearStartMonth": 0,
	"templating": { "list": [] },
	"annotations": { "list": [] },
	"links": [],
	"panels": [
		{
			"id": 1,
			"type": "row",
			"title": "Overview",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 2,
			"type": "stat",
			"title": "API Target Up",
			"gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "red", "value": null },
							{ "color": "green", "value": 1 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "none",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "up{job=\"chevrotain-api\", instance=\"chevrotain-web:3080\"}",
					"refId": "A"
				}
			]
		},
		{
			"id": 3,
			"type": "stat",
			"title": "Zero Host Up",
			"gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "red", "value": null },
							{ "color": "green", "value": 1 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "none",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "up{job=\"node\", instance=\"zero\"}",
					"refId": "A"
				}
			]
		},
		{
			"id": 4,
			"type": "stat",
			"title": "Query Requests / min",
			"gridPos": { "h": 4, "w": 5, "x": 8, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "ops",
					"decimals": 2
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "area",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "sum(rate(http_requests_total{job=\"chevrotain-api\", route=\"/api/query\"}[$__rate_interval])) * 60",
					"refId": "A"
				}
			]
		},
		{
			"id": 5,
			"type": "stat",
			"title": "Mutate Requests / min",
			"gridPos": { "h": 4, "w": 5, "x": 13, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "ops",
					"decimals": 2
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"colorMode": "value",
				"graphMode": "area",
				"textMode": "value"
			},
			"targets": [
				{
					"expr": "sum(rate(http_requests_total{job=\"chevrotain-api\", route=\"/api/mutate\"}[$__rate_interval])) * 60",
					"refId": "A"
				}
			]
		},
		{
			"id": 6,
			"type": "gauge",
			"title": "Zero API Error Rate",
			"gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "orange", "value": 1 },
							{ "color": "red", "value": 5 }
						]
					}
				},
				"overrides": []
			},
			"options": {
				"reduceOptions": { "calcs": ["lastNotNull"] },
				"showThresholdMarkers": true,
				"showThresholdLabels": false
			},
			"targets": [
				{
					"expr": "100 * sum(rate(http_requests_total{job=\"chevrotain-api\", route=~\"/api/query|/api/mutate\", ok=\"false\"}[$__rate_interval])) / clamp_min(sum(rate(http_requests_total{job=\"chevrotain-api\", route=~\"/api/query|/api/mutate\"}[$__rate_interval])), 0.0001)",
					"refId": "A"
				}
			]
		},
		{
			"id": 7,
			"type": "timeseries",
			"title": "Zero API Throughput",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "reqps",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 2,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
			},
			"targets": [
				{
					"expr": "sum(rate(http_requests_total{job=\"chevrotain-api\", route=\"/api/query\"}[$__rate_interval]))",
					"legendFormat": "Query",
					"refId": "A"
				},
				{
					"expr": "sum(rate(http_requests_total{job=\"chevrotain-api\", route=\"/api/mutate\"}[$__rate_interval]))",
					"legendFormat": "Mutate",
					"refId": "B"
				}
			]
		},
		{
			"id": 8,
			"type": "timeseries",
			"title": "Zero API P95 Latency",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "s",
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 10,
						"lineInterpolation": "smooth",
						"lineWidth": 2,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
			},
			"targets": [
				{
					"expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{job=\"chevrotain-api\", route=~\"/api/query|/api/mutate\"}[$__rate_interval])))",
					"legendFormat": "{{route}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 9,
			"type": "row",
			"title": "Zero Host",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
			"collapsed": false,
			"panels": []
		},
		{
			"id": 10,
			"type": "timeseries",
			"title": "CPU Busy % (zero host)",
			"gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "percent",
					"min": 0,
					"max": 100,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 2,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
			},
			"targets": [
				{
					"expr": "100 * (1 - avg(rate(node_cpu_seconds_total{job=\"node\", instance=\"zero\", mode=\"idle\"}[$__rate_interval])))",
					"legendFormat": "CPU Busy",
					"refId": "A"
				}
			]
		},
		{
			"id": 11,
			"type": "timeseries",
			"title": "RAM Used % (zero host)",
			"gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "percent",
					"min": 0,
					"max": 100,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 2,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
			},
			"targets": [
				{
					"expr": "100 * (1 - node_memory_MemAvailable_bytes{job=\"node\", instance=\"zero\"} / node_memory_MemTotal_bytes{job=\"node\", instance=\"zero\"})",
					"legendFormat": "RAM Used",
					"refId": "A"
				}
			]
		},
		{
			"id": 12,
			"type": "timeseries",
			"title": "Root FS Used % (zero host)",
			"gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"unit": "percent",
					"min": 0,
					"max": 100,
					"custom": {
						"drawStyle": "line",
						"fillOpacity": 20,
						"lineInterpolation": "smooth",
						"lineWidth": 2,
						"showPoints": "never",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					}
				},
				"overrides": []
			},
			"options": {
				"tooltip": { "mode": "multi", "sort": "desc" },
				"legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
			},
			"targets": [
				{
					"expr": "100 * (1 - node_filesystem_avail_bytes{job=\"node\", instance=\"zero\", mountpoint=\"/\", fstype!=\"rootfs\"} / node_filesystem_size_bytes{job=\"node\", instance=\"zero\", mountpoint=\"/\", fstype!=\"rootfs\"})",
					"legendFormat": "Root FS Used",
					"refId": "A"
				}
			]
		}
	],
	"version": 1
}
