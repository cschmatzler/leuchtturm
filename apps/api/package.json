{
	"name": "@chevrotain/api",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./*": "./src/*.ts"
	},
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "rolldown -c",
		"start": "node dist/server.js"
	},
	"dependencies": {
		"@chevrotain/core": "workspace:*",
		"@chevrotain/zero": "workspace:*",
		"@effect/opentelemetry": "4.0.0-beta.34",
		"@effect/platform-node": "4.0.0-beta.34",
		"@opentelemetry/api": "1.9.0",
		"@opentelemetry/context-async-hooks": "2.6.0",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
		"@opentelemetry/exporter-trace-otlp-http": "0.213.0",
		"@opentelemetry/instrumentation": "0.213.0",
		"@opentelemetry/instrumentation-pg": "0.65.0",
		"@opentelemetry/instrumentation-undici": "0.23.0",
		"@opentelemetry/resources": "2.6.0",
		"@opentelemetry/sdk-metrics": "^2.6.0",
		"@opentelemetry/sdk-trace-base": "2.6.0",
		"@rocicorp/zero": "0.26.1",
		"autumn-js": "1.0.5",
		"effect": "4.0.0-beta.34",
		"prom-client": "15.1.3"
	},
	"devDependencies": {
		"rolldown": "1.0.0-rc.9",
		"typescript": "5.9.3"
	}
