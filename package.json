{
	"name": "leuchtturm",
	"private": true,
	"workspaces": [
		"infra",
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"devDependencies": {
		"@effect/language-service": "^0.85.1",
		"@leuchtturm/infra": "workspace:*",
		"@types/node": "25.6.0",
		"sst": "4.12.2",
		"typescript": "6.0.3",
		"vite-plus": "0.1.19"
	},
	"engines": {
		"node": ">=25.0.0"
	},
	"packageManager": "pnpm@10.28.0",
	"pnpm": {
		"overrides": {
			"effect": "4.0.0-beta.56"
		},
		"peerDependencyRules": {
			"allowedVersions": {
				"@effect/sql-pg": "4.0.0-beta.56"
			}
		},
		"patchedDependencies": {
			"drizzle-orm@1.0.0-beta.21": "patches/drizzle-orm@1.0.0-beta.21.patch"
		}
	},
	"trustedDependencies": [
		"@rocicorp/zero-sqlite3"
	]
}
