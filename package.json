{
	"name": "leuchtturm",
	"private": true,
	"workspaces": [
		"infra",
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "sst dev",
		"lint": "oxlint",
		"test": "vitest run",
		"fmt": "oxfmt --write",
		"check": "oxfmt --check && oxlint"
	},
	"devDependencies": {
		"@cloudyskysoftware/pulumi-render": "0.5.5",
		"@effect/language-service": "0.86.1",
		"@leuchtturm/infra": "workspace:*",
		"@pulumi/pulumi": "3.238.0",
		"@pulumiverse/grafana": "2.29.1",
		"@types/node": "25.7.0",
		"happy-dom": "20.9.0",
		"oxfmt": "0.49.0",
		"oxlint": "1.64.0",
		"oxlint-tsgolint": "0.22.1",
		"sst": "4.14.1",
		"typescript": "6.0.3",
		"vite": "8.0.12",
		"vitest": "4.1.6"
	},
	"trustedDependencies": [
		"@rocicorp/zero-sqlite3"
	]
}
