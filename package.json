{
	"name": "leuchtturm",
	"private": true,
	"workspaces": [
		"infra",
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "fnox exec -- sst dev",
		"lint": "oxlint",
		"lint-effect": "effect-language-service diagnostics --project ./tsconfig.json --format text",
		"test": "vitest run",
		"fmt": "oxfmt --write",
		"check": "oxfmt --check && oxlint && effect-language-service diagnostics --project ./tsconfig.json --format text"
	},
	"devDependencies": {
		"@cloudyskysoftware/pulumi-render": "0.5.5",
		"@effect/language-service": "0.86.1",
		"@leuchtturm/infra": "workspace:*",
		"@pulumi/pulumi": "3.239.0",
		"@pulumiverse/grafana": "2.30.0",
		"@types/node": "25.8.0",
		"happy-dom": "20.9.0",
		"oxfmt": "0.50.0",
		"oxlint": "1.65.0",
		"oxlint-tsgolint": "0.22.1",
		"sst": "4.14.1",
		"typescript": "6.0.3",
		"vite": "8.0.13",
		"vitest": "4.1.6"
	},
	"overrides": {
		"drizzle-orm": "1.0.0-rc.2",
		"kysely": "0.29.0",
		"postgres": "3.4.9",
		"solid-js": "1.9.13"
	},
	"trustedDependencies": [
		"@rocicorp/zero-sqlite3"
	]
}
