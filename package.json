{
	"name": "leuchtturm",
	"private": true,
	"workspaces": [
		"infra",
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"devDependencies": {
		"@effect/language-service": "0.85.1",
		"@leuchtturm/infra": "workspace:*",
		"@types/node": "25.6.0",
		"happy-dom": "20.9.0",
		"portless": "0.12.0",
		"sst": "4.12.11",
		"typescript": "6.0.3",
		"vite-plus": "0.1.20"
	},
	"engines": {
		"node": ">=25.0.0"
	},
	"packageManager": "pnpm@11.0.4",
	"pnpm": {
		"overrides": {
			"effect": "4.0.0-beta.59"
		},
		"peerDependencyRules": {
			"allowedVersions": {
				"@effect/sql-pg": "4.0.0-beta.59"
			}
		}
	},
	"trustedDependencies": [
		"@rocicorp/zero-sqlite3"
	]
}
